<!DOCTYPE html>
<html>
  <head>
    <title>Rails Chinook Ransack</title>
    <meta name='viewport' content='width=device-width,initial-scale=1'>
    <meta name='turbo-prefetch' content='false'>

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag 'application', 'data-turbo-track': 'reload' unless Rails.env.test? %>
    <%= javascript_importmap_tags unless Rails.env.test? %>
  </head>

  <body>
    <%= render 'layouts/header' %>
    <div class='container-fluid my-3'>
      <% if notice.present? %>
        <div class="alert alert-success alert-dismissible fade show mx-3" role="alert">
          <%= notice %>
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
      <% end %>
      <% if alert.present? %>
        <div class="alert alert-warning alert-dismissible fade show mx-3" role="alert">
          <%= alert %>
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
      <% end %>
      <div class='row px-3'>
        <%= yield %>
      </div>
    </div>
  </body>
</html>
