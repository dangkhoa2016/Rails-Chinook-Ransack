<% if user_signed_in? %>
  <div class="dropdown">
    <button class="btn btn-outline-light dropdown-toggle d-flex align-items-center gap-1"
            type="button" data-bs-toggle="dropdown" aria-expanded="false">
      <i class="bi bi-person-circle"></i>
      <span class="d-none d-md-inline"><%= current_user.display_name %></span>
      <% if current_user.admin? %>
        <span class="badge bg-warning text-dark ms-1">Admin</span>
      <% end %>
    </button>
    <ul class="dropdown-menu dropdown-menu-end">
      <li>
        <span class="dropdown-item-text text-muted small"><%= current_user.email %></span>
      </li>
      <li><hr class="dropdown-divider"></li>
      <li>
        <%= link_to edit_user_registration_path, class: "dropdown-item" do %>
          <i class="bi bi-person-gear me-2"></i>Edit Profile
        <% end %>
      </li>
      <li><hr class="dropdown-divider"></li>
      <li>
        <%= button_to destroy_user_session_path, method: :delete,
            class: "dropdown-item text-danger",
            form: { data: { turbo: false } } do %>
          <i class="bi bi-box-arrow-right me-2"></i>Sign Out
        <% end %>
      </li>
    </ul>
  </div>
<% else %>
  <%= link_to new_user_session_path, class: "btn btn-outline-light" do %>
    <i class="bi bi-person me-1"></i>Sign In
  <% end %>
<% end %>
